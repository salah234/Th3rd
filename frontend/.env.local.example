# Backend API (FastAPI over Supabase). Defaults to local dev if unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sanity (content layer). Get projectId from https://sanity.io/manage after
# creating a project, or run `npx sanity login` then `npx sanity init` in ./frontend.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Only needed for reading drafts/previews or a private dataset. Published
# content on a public dataset reads without a token.
SANITY_API_READ_TOKEN=
