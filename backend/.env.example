# ── Th3rd backend (FastAPI) ──────────────────────────────────────────────────
# Copy to `.env` and fill in. Never commit the real `.env`.

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS — the Next.js storefront origin allowed to call this API
FRONTEND_ORIGIN=http://localhost:3000

# Supabase — Postgres, Auth (JWT), Storage
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Pooled connection string from the Supabase dashboard (Project → Database)
DATABASE_URL=postgresql+psycopg://postgres:<password>@<host>:5432/postgres

# Redis — optional, for caching / rate limiting (e.g. local install or hosted)
REDIS_URL=redis://localhost:6379

# Stripe (added in TH-5x)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email / notifications (added in TH-73)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
